# iTrialSpace environment — this machine (Duke DRCC). Gitignored; edit freely.
# Read automatically by infra/slurm/env.sh and itrialspace.config.settings.

# ── Data root (inputs: raw_ct/ masks/ profiles/ meta/) ──────────────────────
ITRIALSPACE_DATA_DIR="put your data path here"

# ── Output root (generated: manifests/ inserted_masks/ generated_cts/ ...) ──
# Defaults to ITRIALSPACE_DATA_DIR. Uncomment to send all outputs elsewhere:
ITRIALSPACE_OUTPUT_DIR="put your path here"

# ── NoduleMap build artifacts (embeddings, edges, metadata) ─────────────────
# Default would be $ITRIALSPACE_OUTPUT_DIR/nodulemap_artifacts; set explicitly here:
NODULEMAP_ARTIFACTS="put your path"

# ── Conda env used by SLURM scripts ─────────────────────────────────────────
ITRIALSPACE_CONDA_ENV=itrialspace

# ── Service ports ────────────────────────────────────────────────────────────
NODULEMAP_PORT=8422
RETRIEVER_API_PORT=8421
RETRIEVER_UI_PORT=8501

# ── SLURM partitions (Duke DRCC) ────────────────────────────────────────────
SLURM_PARTITION_GPU=vram48
SLURM_PARTITION_CPU=defq

# ── NodMAISI synthesis model weights (Step 3 of the pipeline) ───────────────
NODMAISI_MODELS_DIR="put your path here"


# ── Optional CADe/CADx external dependencies (see docs) ─────────────────────
# EVAL_WEIGHTS_DIR=/path/to/weights
# EVAL_CONFIGS_DIR=/path/to/configs

# HuggingFace access token (gitignored; local only). Clear before sharing.
HF_TOKEN="your HuggingFace access token"
