# iTrialSpace environment configuration — copy to `.env` and edit for your machine.
# These variables drive ALL path resolution; nothing is hardcoded in code or configs.
#
#   cp .env.example .env
#
# `itrialspace.config.settings` reads these (falling back to the defaults shown).

# ── Data root ────────────────────────────────────────────────────────────────
# Single base directory holding the unified data layout:
#   $ITRIALSPACE_DATA_DIR/{raw_ct,masks,profiles,meta,manifests,...}
# Default: ~/.itrialspace/data
ITRIALSPACE_DATA_DIR=/path/to/iTrialSpace/data

# Repo root (auto-detected from the installed package if unset).
# ITRIALSPACE_ROOT=/home/you/itrialspace

# Directory for generated outputs (manifests, inserted masks, synthetic CTs, reports).
# Default: $ITRIALSPACE_DATA_DIR
# ITRIALSPACE_OUTPUT_DIR=/path/to/iTrialSpace/outputs

# ── Build artifacts ──────────────────────────────────────────────────────────
# Where NoduleMap build artifacts (embeddings, edge graphs, metadata) are written —
# and read back from when serving. Set this to point the server at pre-built artifacts,
# or to choose where `its-nodulemap build/edges` (and rebuild_nodulemap.sub) save them.
# Default: $ITRIALSPACE_OUTPUT_DIR/nodulemap_artifacts
# NODULEMAP_ARTIFACTS=/path/to/iTrialSpace/outputs/nodulemap_artifacts
# NODULEMAP_EXPORTS=/path/to/iTrialSpace/outputs/nodulemap_exports   # neighbour/donor exports

# ── HuggingFace access token (VLM eval: MedGemma is gated; some LLaVA-Med too) ──
# Create one at https://huggingface.co/settings/tokens and accept each gated model's
# license. Read by itrialspace.config.settings.hf_token() and passed to the model
# loaders — NEVER hardcoded in code. Leave blank for public-only models (BiomedCLIP
# needs no token). When sharing this repo, clear this value; each user supplies their
# own. (Both HF_TOKEN and the legacy HUGGING_FACE_HUB_TOKEN are honoured.)
# HF_TOKEN=

# ── Model weights (NOT bundled — see docs/installation.md) ──────────────────
# NodMAISI synthesis model weights (autoencoder.pt, diffusion_unet.pt, controlnet *.pt)
# NODMAISI_MODELS_DIR=/path/to/nodmaisi/models

# ── Service ports ────────────────────────────────────────────────────────────
NODULEMAP_PORT=8422
RETRIEVER_API_PORT=8421
RETRIEVER_UI_PORT=8501

# ── HPC / SLURM (only used by infra/slurm/*) ────────────────────────────────
ITRIALSPACE_CONDA_ENV=itrialspace
SLURM_PARTITION_GPU=vram48
SLURM_PARTITION_CPU=defq
# SLURM_ACCOUNT=
# CONDA_PROFILE=/cm/shared/apps/miniconda/etc/profile.d/conda.sh
